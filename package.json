{
  "name": "@conducivemammal/shopify-liquidator",
  "version": "0.1.2",
  "description": "Interactive CLI for deleting selected Shopify themes",
  "type": "module",
  "bin": {
    "theme-liquidate": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "start": "node ./dist/cli.js",
    "test": "node --test",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "shopify",
    "cli",
    "themes",
    "ink"
  ],
  "author": "Liam Merlyn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ConduciveMammal/shopify-liquidator.git"
  },
  "homepage": "https://github.com/ConduciveMammal/shopify-liquidator#readme",
  "bugs": {
    "url": "https://github.com/ConduciveMammal/shopify-liquidator/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ink": "^6.3.1",
    "react": "^19.2.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.1"
  }
}
